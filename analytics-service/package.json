{
  "name": "analytics-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.2.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "scrape:once": "tsx src/scraper/cli.ts once",
    "scrape:loop": "tsx src/scraper/cli.ts loop",
    "scrape:local": "bash ../scripts/run-analytics-scraper.sh"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.0",
    "dotenv": "^16.6.1",
    "hono": "^4.10.1"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
